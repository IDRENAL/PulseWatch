make up          — поднять весь стек (docker compose up -d)
make down        — остановить
make logs        — логи всех сервисов
make shell       — bash в контейнере app
make migrate     — alembic upgrade head
make test        — pytest -v
make flower      — открыть http://localhost:5555
make agent       — запустить агент локально (без systemd)
