{
  "uid": "pulsewatch-business",
  "title": "PulseWatch — Business metrics",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "tags": ["pulsewatch", "business"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Users",
      "description": "Всего зарегистрированных юзеров (Gauge, обновляется каждые 30с)",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "pulsewatch_users_total", "refId": "A"}
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "fixed", "fixedColor": "blue"}
        }
      }
    },
    {
      "id": 2,
      "type": "piechart",
      "title": "Servers by status",
      "description": "Распределение серверов по статусу (active / inactive / paused)",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "pulsewatch_servers_total",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "options": {
        "pieType": "donut",
        "legend": {"displayMode": "list", "placement": "right", "values": ["value"]},
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Open alerts",
      "description": "Алерт-события без resolved_at. >0 жёлтый, >5 красный.",
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "pulsewatch_open_alerts_total", "refId": "A"}
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 1, "color": "yellow"},
              {"value": 6, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Metrics ingest rate by kind",
      "description": "Сколько метрик принимаем от агентов в секунду (system vs docker)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (kind) (rate(pulsewatch_metrics_ingested_total[1m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Logs persistence rate",
      "description": "Строки логов, записанные в БД, в секунду (batch flush каждую секунду)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(pulsewatch_logs_persisted_total[1m])",
          "legendFormat": "lines/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Alert events created (per minute)",
      "description": "Сколько алерт-событий триггерится в минуту threshold-проверкой",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "increase(pulsewatch_alert_events_created_total[1m])",
          "legendFormat": "alerts/min",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Notifications by channel × status",
      "description": "Уведомления в секунду — отдельная линия для telegram/email × success/failed/skipped",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (channel, status) (rate(pulsewatch_notifications_sent_total[5m]))",
          "legendFormat": "{{channel}} / {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    }
  ]
}
